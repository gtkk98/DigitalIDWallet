#:kivy 2.3.1

<LoginScreen>:
    BoxLayout:
        orientation: "vertical"
        padding: 40
        spacing: 20

        Label:
            text: "Digital ID Wallet"
            font_size: 32
            size_hint_y: 0.3

        TextInput:
            id: email
            hint_text: "Email"
            multiline: False
            size_hint_y: 0.2

        TextInput:
            id: password
            hint_text: "Password"
            multiline: False
            password: True
            size_hint_y: 0.2

        Button:
            text: "Login"
            size_hint_y: 0.2
            on_release:
                app.login(email.text, password.text)

        Button:
            text: "Register"
            size_hint_y: 0.2
            on_release:
                app.root.current = "register"

<RegisterScreen>:
    BoxLayout:
        orientation: "vertical"
        padding: 40
        spacing: 20

        Label:
            text: "Register"
            font_size: 32
            size_hint_y: 0.2

        TextInput:
            id: name
            hint_text: "Full Name"
            multiline: False
            size_hint_y: 0.15

        TextInput:
            id: email
            hint_text: "Email"
            multiline: False
            size_hint_y: 0.15

        TextInput:
            id: password
            hint_text: "Password"
            multiline: False
            password: True
            size_hint_y: 0.15

        Button:
            text: "Register"
            size_hint_y: 0.2
            on_release:
                app.register(name.text, email.text, password.text)

        Button:
            text: "Back to Login"
            size_hint_y: 0.1
            on_release:
                app.root.current = "login"

<DashboardScreen>:
    BoxLayout:
        orientation: "vertical"
        padding: 40
        spacing: 20

        Label:
            text: "Digital ID Wallet"
            font_size: 28

        Button:
            text: "Add New ID"
            on_release:
                app.root.current = "add_id"

        Button:
            text: "View My IDs"
            on_release:
                app.root.current = "view_ids"

<AddIDScreen>:
    BoxLayout:
        orientation: "vertical"
        padding: 30
        spacing: 15

        Label:
            text: "Add Digital ID"
            font_size: 28

        TextInput:
            id: id_type
            hint_text: "ID Type (NIC / Driving License / Passport)"
            multiline: False

        TextInput:
            id: id_number
            hint_text: "ID Number"
            multiline: False

        TextInput:
            id: expiry_date
            hint_text: "Expiry Date"
            multiline: False

        TextInput:
            id: image_path
            hint_text: "Image Path"
            multiline: False

        Button:
            text: "Save ID"
            on_release:
                app.save_id(id_type.text, id_number.text, expiry_date.text, image_path.text)

        Button:
            text: "Back"
            on_release:
                app.root.current = "dashboard"

<ViewIDsScreen>:
    BoxLayout:
        orientation: "vertical"
        padding: 20
        spacing: 20

        Label:
            text: "My Digital IDs"
            font_size: 28

        ScrollView:

            GridLayout:
                id: id_list
                cols: 1
                spacing: 20
                size_hint_y: None
                height: self.minimum_height

        Button:
            text: "Back"
            size_hint_y: None
            height: 50
            on_release:
                app.root.current = "dashboard"
