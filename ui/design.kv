#:kivy 2.3.1

<LoginScreen>:
    BoxLayout:
        orientation: "vertical"
        padding: 40
        spacing: 20

        Label:
            text: "Digital ID Wallet"
            font_size: 32
            size_hint_y: 0.3

        TextInput:
            id: email
            hint_text: "Email"
            multiline: False
            size_hint_y: 0.2

        TextInput:
            id: password
            hint_text: "Password"
            multiline: False
            password: True
            size_hint_y: 0.2

        Button:
            text: "Login"
            size_hint_y: 0.2
            on_release:
                app.login(email.text, password.text)

        Button:
            text: "Register"
            size_hint_y: 0.2
            on_release:
                app.root.current = "register"

<RegisterScreen>:
    BoxLayout:
        orientation: "vertical"
        padding: 40
        spacing: 20

        Label:
            text: "Register"
            font_size: 32
            size_hint_y: 0.2

        TextInput:
            id: name
            hint_text: "Full Name"
            multiline: False
            size_hint_y: 0.15

        TextInput:
            id: email
            hint_text: "Email"
            multiline: False
            size_hint_y: 0.15

        TextInput:
            id: password
            hint_text: "Password"
            multiline: False
            password: True
            size_hint_y: 0.15

        Button:
            text: "Register"
            size_hint_y: 0.2
            on_release:
                app.register(name.text, email.text, password.text)

        Button:
            text: "Back to Login"
            size_hint_y: 0.1
            on_release:
                app.root.current = "login"

<DashboardScreen>:
    BoxLayout:
        orientation: "vertical"
        Label:
            text: "Welcome to Digital ID Wallet"
            font_size: 28